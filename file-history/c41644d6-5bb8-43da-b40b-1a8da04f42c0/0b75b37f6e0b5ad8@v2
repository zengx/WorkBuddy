<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zengx.wbsync.push</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-c</string>
        <string>WB_SYNC_AUTO=1 /Users/zengx/.workbuddy/wb-sync.sh push</string>
    </array>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/tmp/wbsync-push.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/wbsync-push.err</string>
</dict>
</plist>
