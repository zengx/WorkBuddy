{
  "name": "ppt-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --outDir ../artifacts",
    "preview": "vite preview --outDir ../artifacts",
    "build:slides": "rm -rf ./dist-slides && node scripts/build-slides.js",
