<!-- Template: 中国风-灯笼喜庆 (Ending #1036) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-b from-[#f5e8e0] to-[#e8d8c8]">
  <!-- 灯笼 - 左 -->
  <div class="absolute top-[8%] left-[15%]">
    <!-- 灯笼顶部 -->
    <div class="w-[80px] h-[15px] bg-[#8b7355] mx-auto rounded-t-[100%]"></div>
    <!-- 灯笼身体 -->
    <div class="w-[100px] h-[140px] bg-gradient-to-br from-[#c8102e] via-[#e62e3a] to-[#c8102e] mx-auto relative shadow-inner" style="border-radius: 50% 50% 50% 50% / 15% 15% 85% 85%; box-shadow: inset 0 0 20px rgba(0,0,0,0.2);">
      <div class="absolute top-[30%] left-[10%] right-[10%] h-[2px] bg-[#f5d908]"></div>
      <div class="absolute top-[50%] left-[10%] right-[10%] h-[2px] bg-[#f5d908]"></div>
      <div class="absolute top-[70%] left-[10%] right-[10%] h-[2px] bg-[#f5d908]"></div>
    </div>
    <!-- 灯笼底部 -->
    <div class="w-[80px] h-[15px] bg-[#8b7355] mx-auto rounded-b-[100%]"></div>
    <!-- 流苏 -->
    <div class="w-[40px] h-[50px] mx-auto bg-gradient-to-b from-[#f5d908] to-transparent" style="clip-path: polygon(40% 0, 60% 0, 60% 60%, 50% 100%, 40% 60%);"></div>
  </div>

  <!-- 灯笼 - 右 -->
  <div class="absolute top-[8%] right-[15%]">
    <div class="w-[80px] h-[15px] bg-[#8b7355] mx-auto rounded-t-[100%]"></div>
    <div class="w-[100px] h-[140px] bg-gradient-to-br from-[#c8102e] via-[#e62e3a] to-[#c8102e] mx-auto relative shadow-inner" style="border-radius: 50% 50% 50% 50% / 15% 15% 85% 85%; box-shadow: inset 0 0 20px rgba(0,0,0,0.2);">
      <div class="absolute top-[30%] left-[10%] right-[10%] h-[2px] bg-[#f5d908]"></div>
      <div class="absolute top-[50%] left-[10%] right-[10%] h-[2px] bg-[#f5d908]"></div>
      <div class="absolute top-[70%] left-[10%] right-[10%] h-[2px] bg-[#f5d908]"></div>
    </div>
    <div class="w-[80px] h-[15px] bg-[#8b7355] mx-auto rounded-b-[100%]"></div>
    <div class="w-[40px] h-[50px] mx-auto bg-gradient-to-b from-[#f5d908] to-transparent" style="clip-path: polygon(40% 0, 60% 0, 60% 60%, 50% 100%, 40% 60%);"></div>
  </div>

  <!-- 祥云装饰 -->
  <div class="absolute bottom-[12%] left-1/2 -translate-x-1/2 flex gap-[10px] text-[40px] text-[#8b7355]/20">☁☁☁☁</div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center">
    <div class="text-center max-w-[70%] mx-auto" style="margin-top: 60px;">
      <h1 class="text-[68px] text-[#c8102e] mb-10 font-normal tracking-[10px]" style="font-family: 'STKaiti', 'KaiTi', serif;">致谢</h1>
      
      <div class="flex items-center justify-center gap-4 mb-9">
        <div class="w-[80px] h-[2px] bg-[#c8102e]"></div>
        <div class="w-[12px] h-[12px] bg-[#f5d908] rounded-full"></div>
        <div class="w-[80px] h-[2px] bg-[#c8102e]"></div>
      </div>
      
      <p class="text-[24px] text-gray-600 leading-relaxed tracking-[2px]" style="font-family: 'STKaiti', 'KaiTi', serif;">欢迎交流指导</p>
    </div>
  </div>
</div>
