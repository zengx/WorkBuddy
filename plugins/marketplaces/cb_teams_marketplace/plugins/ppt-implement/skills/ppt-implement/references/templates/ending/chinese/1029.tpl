<!-- Template: 中国风-水墨山水 (Ending #1029) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-b from-[#f8f8f0] to-[#e8e8d8]">
  <!-- 水墨山水装饰底部 -->
  <div class="absolute bottom-0 left-0 right-0 h-[35%] bg-gradient-to-t from-gray-600/15 via-gray-600/8 to-transparent rounded-t-[50%]"></div>
  
  <!-- 山峰剪影 - 左 -->
  <div class="absolute bottom-[8%] left-[10%] w-[20%] h-[25%] bg-gradient-to-t from-gray-800/20 via-gray-700/10 to-transparent" style="clip-path: polygon(0 100%, 30% 20%, 60% 40%, 100% 0, 100% 100%);"></div>
  
  <!-- 山峰剪影 - 右 -->
  <div class="absolute bottom-[5%] right-[15%] w-[25%] h-[30%] bg-gradient-to-t from-gray-700/18 via-gray-600/9 to-transparent" style="clip-path: polygon(0 80%, 20% 30%, 50% 50%, 80% 10%, 100% 60%, 100% 100%, 0 100%);"></div>

  <!-- 印章装饰 -->
  <div class="absolute top-[7%] right-[7%] w-[70px] h-[70px] border-3 border-[#c8102e] bg-[#c8102e]/10 rotate-[5deg] flex items-center justify-center">
    <div class="text-[#c8102e] text-[15px] font-bold leading-tight" style="font-family: 'STKaiti', 'KaiTi', serif;">谢<br/>谢</div>
  </div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center">
    <div class="text-center max-w-[80%] mx-auto">
      <h1 class="text-[64px] text-[#2c2c2c] mb-9 font-normal tracking-[7px]" style="font-family: 'STKaiti', 'KaiTi', serif;">感谢聆听</h1>
      
      <div class="w-[100px] h-[2px] bg-gradient-to-r from-transparent via-[#8b7355] to-transparent mx-auto mb-8"></div>
      
      <p class="text-[22px] text-gray-600 leading-relaxed tracking-[2px]" style="font-family: 'STKaiti', 'KaiTi', serif;">山高水长，后会有期</p>
    </div>
  </div>
</div>
