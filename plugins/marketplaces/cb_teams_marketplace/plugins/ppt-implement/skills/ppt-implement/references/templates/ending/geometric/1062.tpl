<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);">
  <!-- 大圆形装饰 -->
  <div class="absolute top-[-100px] left-[-100px] w-[400px] h-[400px] rounded-full bg-[rgba(255,255,255,0.15)]"></div>
  <div class="absolute top-1/2 -translate-y-1/2 right-[-150px] w-[500px] h-[500px] rounded-full bg-[rgba(255,255,255,0.12)]"></div>
  <div class="absolute bottom-[-120px] left-[30%] w-[350px] h-[350px] rounded-full bg-[rgba(255,255,255,0.18)]"></div>
  
  <!-- 中心圆环 -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[280px] h-[280px] rounded-full border-[3px] border-[rgba(255,255,255,0.4)]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[220px] h-[220px] rounded-full border-2 border-[rgba(255,255,255,0.3)]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[160px] h-[160px] rounded-full bg-[rgba(255,255,255,0.1)]"></div>
  
  <!-- 内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col items-center justify-center relative z-[2]">
    <h1 class="text-[56px] font-bold text-[#2c3e50] mb-[40px]" style="font-family: 'Arial', 'Microsoft YaHei', sans-serif; text-shadow: 0 2px 8px rgba(255,255,255,0.5);">致谢</h1>
    <p class="text-[28px] text-[#34495e] leading-[1.6]" style="font-family: 'Arial', 'Microsoft YaHei', sans-serif;">欢迎交流与指导</p>
  </div>
  
  <!-- 小圆形装饰 -->
  <div class="absolute top-[18%] left-[15%] w-[60px] h-[60px] rounded-full bg-[rgba(255,255,255,0.25)]" style="animation: float 3s ease-in-out infinite;"></div>
  <div class="absolute top-[65%] right-[18%] w-[50px] h-[50px] rounded-full bg-[rgba(255,255,255,0.3)]" style="animation: float 4s ease-in-out infinite 1s;"></div>
  <div class="absolute bottom-[15%] left-[25%] w-[70px] h-[70px] rounded-full bg-[rgba(255,255,255,0.2)]" style="animation: float 3.5s ease-in-out infinite 0.5s;"></div>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-15px); }
    }
  </style>
</div>
