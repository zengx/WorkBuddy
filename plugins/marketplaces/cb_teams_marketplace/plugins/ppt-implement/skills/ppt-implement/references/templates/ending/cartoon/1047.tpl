<!-- Template: 卡通风-冰淇淋甜筒 (Ending #1047) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-b from-[#fff5f0] to-[#f0f8ff]">
  <!-- 冰淇淋 - 左边 -->
  <div class="absolute bottom-[10%] left-[12%]">
    <!-- 冰淇淋球 -->
    <div class="w-[100px] h-[100px] rounded-full shadow-xl relative z-[2]" style="background: radial-gradient(circle at 30% 30%, #ff99cc, #ff6b9d);"></div>
    <!-- 甜筒 -->
    <div class="relative -top-[20px] w-0 h-0 shadow-lg border-l-[50px] border-r-[50px] border-t-[120px] border-l-transparent border-r-transparent border-t-[#d4a574]">
      <!-- 格子纹理 -->
      <div class="absolute -top-[110px] -left-[45px] w-[90px] h-[110px]" style="background: repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(139, 90, 43, 0.2) 8px, rgba(139, 90, 43, 0.2) 16px), repeating-linear-gradient(-45deg, transparent, transparent 8px, rgba(139, 90, 43, 0.2) 8px, rgba(139, 90, 43, 0.2) 16px); clip-path: polygon(50% 100%, 0 0, 100% 0);"></div>
    </div>
  </div>

  <!-- 冰淇淋 - 右边 -->
  <div class="absolute bottom-[10%] right-[12%]">
    <!-- 冰淇淋球 -->
    <div class="w-[95px] h-[95px] rounded-full shadow-xl relative z-[2]" style="background: radial-gradient(circle at 30% 30%, #b388ff, #9966ff);"></div>
    <!-- 甜筒 -->
    <div class="relative -top-[18px] w-0 h-0 shadow-lg border-l-[47px] border-r-[47px] border-t-[115px] border-l-transparent border-r-transparent border-t-[#d4a574]">
      <div class="absolute -top-[105px] -left-[42px] w-[84px] h-[105px]" style="background: repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(139, 90, 43, 0.2) 8px, rgba(139, 90, 43, 0.2) 16px), repeating-linear-gradient(-45deg, transparent, transparent 8px, rgba(139, 90, 43, 0.2) 8px, rgba(139, 90, 43, 0.2) 16px); clip-path: polygon(50% 100%, 0 0, 100% 0);"></div>
    </div>
  </div>

  <!-- 小冰淇淋装饰 - 顶部左 -->
  <div class="absolute top-[12%] left-[20%]">
    <div class="w-[50px] h-[50px] rounded-full shadow-md relative z-[2]" style="background: radial-gradient(circle at 30% 30%, #ffea5c, #ffd700);"></div>
    <div class="relative -top-[10px] w-0 h-0 border-l-[25px] border-r-[25px] border-t-[60px] border-l-transparent border-r-transparent border-t-[#d4a574]"></div>
  </div>

  <!-- 小冰淇淋装饰 - 顶部右 -->
  <div class="absolute top-[15%] right-[22%]">
    <div class="w-[55px] h-[55px] rounded-full shadow-md relative z-[2]" style="background: radial-gradient(circle at 30% 30%, #77dd77, #5fd85f);"></div>
    <div class="relative -top-[10px] w-0 h-0 border-l-[27px] border-r-[27px] border-t-[65px] border-l-transparent border-r-transparent border-t-[#d4a574]"></div>
  </div>

  <!-- 闪光装饰 -->
  <div class="absolute top-[28%] left-[35%] text-[35px] text-[#ffea5c] animate-sparkle">✨</div>
  <div class="absolute bottom-[35%] right-[30%] text-[30px] text-[#ffb347] animate-sparkle-slow">✨</div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center">
    <div class="text-center max-w-[68%] mx-auto">
      <h1 class="text-[70px] text-[#ff6b9d] mb-10 font-bold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif; text-shadow: 3px 3px 0 rgba(255, 107, 157, 0.2);">感谢聆听</h1>
      
      <div class="flex items-center justify-center gap-3 mb-9">
        <div class="w-[18px] h-[18px] bg-[#ff99cc] rounded-full"></div>
        <div class="w-[18px] h-[18px] bg-[#ffea5c] rounded-full"></div>
        <div class="w-[18px] h-[18px] bg-[#77dd77] rounded-full"></div>
        <div class="w-[18px] h-[18px] bg-[#66ccff] rounded-full"></div>
        <div class="w-[18px] h-[18px] bg-[#b388ff] rounded-full"></div>
      </div>
      
      <p class="text-[24px] text-gray-600 leading-relaxed font-semibold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif;">期待下次再见</p>
    </div>
  </div>

  <style>
    @keyframes sparkle {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.3); }
    }
    .animate-sparkle {
      animation: sparkle 2s ease-in-out infinite;
    }
    .animate-sparkle-slow {
      animation: sparkle 2.5s ease-in-out infinite;
    }
  </style>
</div>
