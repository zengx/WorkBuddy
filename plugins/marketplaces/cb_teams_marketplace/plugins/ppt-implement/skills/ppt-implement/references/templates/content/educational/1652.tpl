<!-- Template: 教育风格-变体12 (Content #1652) - HTML入门·标签学习 -->
    <div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden bg-gradient-to-br from-[#18181b] to-[#27272a]">
        
        <!-- HTML标签教学布局 -->
        <div class="w-[1350px] h-[720px] mx-auto my-[20px] flex items-center justify-center">
            <div class="max-w-5xl w-full">
                <div class="text-center mb-5">
                    <h1 class="text-[32px] font-bold text-white mb-2 font-mono">HTML 入门</h1>
                    <p class="text-[16px] text-orange-400 font-mono">常用标签学习</p>
                </div>
                
                <div class="grid grid-cols-2 gap-5">
                    <div class="space-y-3">
                        <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
                            <h3 class="text-[16px] font-bold text-orange-400 mb-3 font-mono">&lt;h1&gt; 标题标签</h3>
                            <div class="bg-gray-900 rounded-lg p-3 font-mono text-[14px]">
                                <span class="text-gray-500">&lt;</span><span class="text-pink-400">h1</span><span class="text-gray-500">&gt;</span><span class="text-green-400">我是一级标题</span><span class="text-gray-500">&lt;/</span><span class="text-pink-400">h1</span><span class="text-gray-500">&gt;</span>
                            </div>
                            <p class="text-[12px] text-gray-400 mt-2">用于定义标题，h1到h6，数字越小标题越大</p>
                        </div>
                        
                        <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
                            <h3 class="text-[16px] font-bold text-orange-400 mb-3 font-mono">&lt;p&gt; 段落标签</h3>
                            <div class="bg-gray-900 rounded-lg p-3 font-mono text-[14px]">
                                <span class="text-gray-500">&lt;</span><span class="text-pink-400">p</span><span class="text-gray-500">&gt;</span><span class="text-green-400">这是一段文字</span><span class="text-gray-500">&lt;/</span><span class="text-pink-400">p</span><span class="text-gray-500">&gt;</span>
                            </div>
                            <p class="text-[12px] text-gray-400 mt-2">用于定义段落，浏览器会自动添加间距</p>
                        </div>
                        
                        <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
                            <h3 class="text-[16px] font-bold text-orange-400 mb-3 font-mono">&lt;a&gt; 链接标签</h3>
                            <div class="bg-gray-900 rounded-lg p-3 font-mono text-[14px]">
                                <span class="text-gray-500">&lt;</span><span class="text-pink-400">a</span> <span class="text-blue-400">href</span>=<span class="text-green-400">"网址"</span><span class="text-gray-500">&gt;</span><span class="text-white">点击跳转</span><span class="text-gray-500">&lt;/</span><span class="text-pink-400">a</span><span class="text-gray-500">&gt;</span>
                            </div>
                            <p class="text-[12px] text-gray-400 mt-2">用于创建超链接，href属性指定跳转地址</p>
                        </div>
                    </div>
                    
                    <div class="space-y-3">
                        <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
                            <h3 class="text-[16px] font-bold text-orange-400 mb-3 font-mono">&lt;img&gt; 图片标签</h3>
                            <div class="bg-gray-900 rounded-lg p-3 font-mono text-[14px]">
                                <span class="text-gray-500">&lt;</span><span class="text-pink-400">img</span> <span class="text-blue-400">src</span>=<span class="text-green-400">"图片地址"</span> <span class="text-blue-400">alt</span>=<span class="text-green-400">"描述"</span><span class="text-gray-500">&gt;</span>
                            </div>
                            <p class="text-[12px] text-gray-400 mt-2">用于插入图片，src是图片路径，alt是备用文字</p>
                        </div>
                        
                        <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
                            <h3 class="text-[16px] font-bold text-orange-400 mb-3 font-mono">&lt;div&gt; 容器标签</h3>
                            <div class="bg-gray-900 rounded-lg p-3 font-mono text-[14px]">
                                <span class="text-gray-500">&lt;</span><span class="text-pink-400">div</span><span class="text-gray-500">&gt;</span><span class="text-green-400">内容区域</span><span class="text-gray-500">&lt;/</span><span class="text-pink-400">div</span><span class="text-gray-500">&gt;</span>
                            </div>
                            <p class="text-[12px] text-gray-400 mt-2">用于分组和布局，是最常用的容器标签</p>
                        </div>
                        
                        <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
                            <h3 class="text-[16px] font-bold text-orange-400 mb-3 font-mono">&lt;ul&gt; 列表标签</h3>
                            <div class="bg-gray-900 rounded-lg p-3 font-mono text-[14px] space-y-0.5">
                                <div><span class="text-gray-500">&lt;</span><span class="text-pink-400">ul</span><span class="text-gray-500">&gt;</span></div>
                                <div class="ml-4"><span class="text-gray-500">&lt;</span><span class="text-pink-400">li</span><span class="text-gray-500">&gt;</span><span class="text-green-400">列表项1</span><span class="text-gray-500">&lt;/</span><span class="text-pink-400">li</span><span class="text-gray-500">&gt;</span></div>
                                <div class="ml-4"><span class="text-gray-500">&lt;</span><span class="text-pink-400">li</span><span class="text-gray-500">&gt;</span><span class="text-green-400">列表项2</span><span class="text-gray-500">&lt;/</span><span class="text-pink-400">li</span><span class="text-gray-500">&gt;</span></div>
                                <div><span class="text-gray-500">&lt;/</span><span class="text-pink-400">ul</span><span class="text-gray-500">&gt;</span></div>
                            </div>
                            <p class="text-[12px] text-gray-400 mt-2">用于创建无序列表，每项用li标签包裹</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
    </div>
