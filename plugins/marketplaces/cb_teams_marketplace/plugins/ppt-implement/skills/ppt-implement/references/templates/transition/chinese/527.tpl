<!-- Template: 中国风-云纹雅韵 (Transition #527) -->
<div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden" style="background: linear-gradient(to bottom, #f8f6f2 0%, #ebe8e0 100%);">
    <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
        <!-- 大面积留白区域 -->
        <div class="absolute inset-0" style="background: radial-gradient(circle at 30% 70%, rgba(139, 69, 19, 0.02) 0%, transparent 50%);"></div>
        
        <!-- 简约竹叶装饰（左下） -->
        <div class="absolute bottom-14 left-14 opacity-20">
            <div class="transform -rotate-12 w-20 h-1 bg-gray-600 rounded-full mb-2"></div>
            <div class="transform rotate-12 w-16 h-1 bg-gray-600 rounded-full ml-3"></div>
        </div>
        
        <!-- 简约竹叶装饰（右上） -->
        <div class="absolute top-14 right-14 opacity-20">
            <div class="transform rotate-12 w-20 h-1 bg-gray-600 rounded-full mb-2"></div>
            <div class="transform -rotate-12 w-16 h-1 bg-gray-600 rounded-full ml-3"></div>
        </div>
        
        <!-- 中央内容区 -->
        <div class="flex items-center justify-center h-full">
            <div class="text-center z-10 px-20">
                <!-- 章节标识 - 圆形背景 -->
                <div class="inline-block mb-8 w-16 h-16 rounded-full flex items-center justify-center" style="background: rgba(139, 69, 19, 0.08);">
                    <span class="text-base font-bold tracking-wider" style="color: #8b4513; font-family: 'KaiTi', serif;">01</span>
                </div>
                
                <!-- 主标题 -->
                <h1 class="text-5xl font-bold mb-6 tracking-wide" style="color: #2d2d2d; font-family: 'KaiTi', serif; line-height: 1.2;">项目背景</h1>
                
                <!-- 简约分隔线 -->
                <div class="flex items-center justify-center gap-3 mb-5">
                    <div class="w-10 h-px" style="background: linear-gradient(to right, transparent, #8b4513);"></div>
                    <div class="w-1 h-1 rounded-full" style="background: #8b4513;"></div>
                    <div class="w-10 h-px" style="background: linear-gradient(to left, transparent, #8b4513);"></div>
                </div>
                
                <!-- 副标题 -->
                <p class="text-lg tracking-wide" style="color: #888; font-family: 'KaiTi', serif;">了解项目的起源与目标</p>
            </div>
        </div>
        
        <!-- 小印章（右下） -->
        <div class="absolute bottom-14 right-16 w-12 h-12 opacity-50 transform rotate-8" style="background: linear-gradient(135deg, #c41e3a 0%, #8b1428 100%); clip-path: polygon(8% 0%, 92% 0%, 100% 8%, 100% 92%, 92% 100%, 8% 100%, 0% 92%, 0% 8%);">
            <div class="w-full h-full flex items-center justify-center">
                <span class="text-xs text-white font-bold" style="font-family: 'KaiTi', serif;">雅</span>
            </div>
        </div>
    </div>
</div>
