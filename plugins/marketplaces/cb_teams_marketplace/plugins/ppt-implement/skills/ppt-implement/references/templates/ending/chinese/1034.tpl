    <div class="text-[#c8102e] text-[18px] font-bold leading-tight tracking-[2px]" style="font-family: 'STKaiti', 'KaiTi', serif;">谢<br/>谢</div>
  </div>

  <!-- 墨点装饰 -->
  <div class="absolute bottom-[25%] left-[15%] w-[18px] h-[18px] rounded-full" style="background: radial-gradient(circle, rgba(40, 40, 40, 0.25) 0%, transparent 70%);"></div>
  <div class="absolute top-[28%] right-[25%] w-[12px] h-[12px] rounded-full" style="background: radial-gradient(circle, rgba(40, 40, 40, 0.2) 0%, transparent 70%);"></div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center">
    <div class="text-center max-w-[75%] mx-auto">
      <h1 class="text-[72px] text-[#2c2c2c] mb-11 font-normal tracking-[12px] relative" style="font-family: 'STKaiti', 'KaiTi', serif;">感谢聆听</h1>
      
      <div class="flex items-center justify-center gap-5 mb-9">
        <div class="w-[100px] h-[2px] bg-gradient-to-r from-transparent to-black/30"></div>
        <div class="w-[8px] h-[8px] bg-black/30 rounded-full"></div>
        <div class="w-[100px] h-[2px] bg-gradient-to-l from-transparent to-black/30"></div>
      </div>
      
      <p class="text-[24px] text-gray-600 leading-relaxed tracking-[3px]" style="font-family: 'STKaiti', 'KaiTi', serif;">期待与您再次相见</p>
