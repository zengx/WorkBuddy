  <!-- 书法笔触装饰 - 左上 -->
  <div class="absolute top-[15%] left-[8%] w-[180px] h-[8px] -rotate-[8deg]" style="background: linear-gradient(90deg, transparent 0%, rgba(40, 40, 40, 0.15) 10%, rgba(40, 40, 40, 0.25) 50%, rgba(40, 40, 40, 0.15) 90%, transparent 100%);"></div>
  
  <!-- 书法笔触装饰 - 右下 -->
  <div class="absolute bottom-[18%] right-[10%] w-[200px] h-[6px] rotate-[5deg]" style="background: linear-gradient(90deg, transparent 0%, rgba(40, 40, 40, 0.12) 15%, rgba(40, 40, 40, 0.2) 50%, rgba(40, 40, 40, 0.12) 85%, transparent 100%);"></div>

  <!-- 印章 - 方形 -->
