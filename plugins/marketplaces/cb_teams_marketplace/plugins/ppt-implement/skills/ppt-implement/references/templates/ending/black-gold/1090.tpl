<!-- Template: 黑金风-金箔质感 (Ending #1090) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: #1a1a2e;">
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
    <!-- 金箔纹理效果 -->
    <div class="absolute -top-[90px] -left-[90px] w-[370px] h-[370px]" style="background: radial-gradient(circle, rgba(212,175,55,0.15) 0%, transparent 70%); filter: blur(38px);"></div>
    <div class="absolute top-1/2 -right-[110px] w-[420px] h-[420px]" style="background: radial-gradient(circle, rgba(255,215,0,0.12) 0%, transparent 70%); filter: blur(42px);"></div>
    <div class="absolute -bottom-[72px] left-[28%] w-[350px] h-[350px]" style="background: radial-gradient(circle, rgba(218,165,32,0.13) 0%, transparent 70%); filter: blur(36px);"></div>
    
    <!-- 金色碎片装饰 -->
    <div class="absolute top-[18%] left-[13%] w-[55px] h-[55px] opacity-30" style="background: linear-gradient(135deg, #d4af37, #ffd700); transform: rotate(15deg); clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);"></div>
    <div class="absolute top-[63%] right-[16%] w-[46px] h-[46px] opacity-25" style="background: linear-gradient(135deg, #ffd700, #daa520); transform: rotate(-20deg); clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);"></div>
    <div class="absolute bottom-[20%] left-[23%] w-[50px] h-[50px] opacity-28" style="background: linear-gradient(135deg, #d4af37, #b8860b); transform: rotate(30deg); clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);"></div>
    
    <!-- 金色边框 -->
    <div class="absolute top-[72px] left-[72px] right-[72px] bottom-[72px] border" style="border-color: rgba(212,175,55,0.4); box-shadow: inset 0 0 30px rgba(255,215,0,0.1);"></div>
    
    <!-- 内容区域 -->
    <div class="absolute inset-0 flex flex-col items-center justify-center z-[2] px-20 py-20">
      <div class="text-5xl font-bold mb-10 text-center" style="text-shadow: 0 0 30px rgba(255,215,0,0.6), 0 2px 10px rgba(0,0,0,0.8); background: linear-gradient(135deg, #ffd700, #d4af37); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: #ffd700;">感谢聆听</div>
      <div class="text-2xl leading-loose font-medium text-center" style="color: #d4af37; text-shadow: 0 1px 5px rgba(0,0,0,0.5);">期待与您再次相见</div>
    </div>
  </div>
</div>
