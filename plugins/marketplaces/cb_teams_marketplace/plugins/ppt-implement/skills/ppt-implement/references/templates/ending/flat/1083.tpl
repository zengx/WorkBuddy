<!-- Template: 扁平风-图标组合 (Ending #1083) -->
<div class="w-[1440px] h-[810px] bg-gradient-to-br from-teal-100 via-pink-50 to-pink-200 relative overflow-hidden">
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
    <!-- 图标装饰 - 心形 -->
    <div class="absolute top-[15%] left-[15%] w-[60px] h-[60px] bg-red-400 opacity-70" style="transform: rotate(45deg);"></div>
    <div class="absolute top-[15%] left-[15%] w-[60px] h-[30px] bg-red-400 rounded-t-full opacity-70" style="transform-origin: bottom center;"></div>
    <div class="absolute top-[15%] left-[15%] w-[30px] h-[60px] bg-red-400 opacity-70" style="border-radius: 60px 0 0 60px; transform-origin: right center;"></div>
    
    <!-- 图标装饰 - 星星 -->
    <svg class="absolute top-[25%] right-[18%] w-[70px] h-[70px] opacity-70" xmlns="http://www.w3.org/2000/svg">
      <polygon points="35,5 42,25 63,25 46,38 53,58 35,45 17,58 24,38 7,25 28,25" fill="#ffd93d"/>
    </svg>
    
    <!-- 图标装饰 - 圆形笑脸 -->
    <svg class="absolute bottom-[20%] left-[20%] w-20 h-20 opacity-70" xmlns="http://www.w3.org/2000/svg">
      <circle cx="40" cy="40" r="38" fill="#6bcf7f"/>
      <circle cx="28" cy="32" r="5" fill="white"/>
      <circle cx="52" cy="32" r="5" fill="white"/>
      <path d="M20,45 Q40,60 60,45" fill="none" stroke="white" stroke-width="4" stroke-linecap="round"/>
    </svg>
    
    <!-- 图标装饰 - 对勾 -->
    <svg class="absolute bottom-[25%] right-[15%] w-[70px] h-[70px] opacity-70" xmlns="http://www.w3.org/2000/svg">
      <circle cx="35" cy="35" r="33" fill="#4ecdc4"/>
      <path d="M15,35 L28,48 L55,20" fill="none" stroke="white" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    
    <!-- 小装饰点 -->
    <div class="absolute top-[40%] left-[30%] w-5 h-5 rounded-full bg-pink-300"></div>
    <div class="absolute top-[60%] right-[35%] w-[25px] h-[25px] rounded-full bg-teal-300"></div>
    
    <!-- 内容区域 -->
    <div class="absolute inset-0 flex flex-col items-center justify-center z-[2]">
      <div class="text-[56px] font-bold text-gray-800 mb-10">谢谢观看</div>
      <div class="text-[28px] text-gray-700 leading-relaxed font-medium text-center">期待您的宝贵意见</div>
    </div>
  </div>
</div>
