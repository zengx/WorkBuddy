<!-- Template: 黑金风-金色线条 (Ending #1089) -->
<div class="w-[1440px] h-[810px] bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-800 relative overflow-hidden">
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
    <!-- 金色线条装饰 -->
    <div class="absolute top-0 left-0 w-full h-[3px]" style="background: linear-gradient(90deg, transparent, #d4af37, #ffd700, #d4af37, transparent);"></div>
    <div class="absolute bottom-0 left-0 w-full h-[3px]" style="background: linear-gradient(90deg, transparent, #d4af37, #ffd700, #d4af37, transparent);"></div>
    
    <!-- 侧边金色线条 -->
    <div class="absolute top-0 left-0 w-0.5 h-full" style="background: linear-gradient(to bottom, transparent, #d4af37 20%, #ffd700 50%, #d4af37 80%, transparent);"></div>
    <div class="absolute top-0 right-0 w-0.5 h-full" style="background: linear-gradient(to bottom, transparent, #d4af37 20%, #ffd700 50%, #d4af37 80%, transparent);"></div>
    
    <!-- 对角线金色装饰 -->
    <div class="absolute top-[13%] left-[8%] w-[185px] h-0.5 opacity-60" style="background: linear-gradient(90deg, transparent, #d4af37, transparent); transform: rotate(-45deg);"></div>
    <div class="absolute bottom-[16%] right-[10%] w-[200px] h-0.5 opacity-70" style="background: linear-gradient(90deg, transparent, #ffd700, transparent); transform: rotate(45deg);"></div>
    
    <!-- 金色方框装饰 -->
    <div class="absolute top-1/2 left-1/2 w-[370px] h-[255px] border-2" style="transform: translate(-50%, -50%); border-color: rgba(212,175,55,0.4);"></div>
    <div class="absolute top-1/2 left-1/2 w-[350px] h-[235px] border" style="transform: translate(-50%, -50%); border-color: rgba(255,215,0,0.3);"></div>
    
    <!-- 角落装饰 -->
    <svg class="absolute top-[45px] left-[45px] w-[55px] h-[55px] opacity-60" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,27 L27,0 M0,0 L55,0 L55,27" stroke="#d4af37" stroke-width="2" fill="none"/>
    </svg>
    <svg class="absolute bottom-[45px] right-[45px] w-[55px] h-[55px] opacity-60" xmlns="http://www.w3.org/2000/svg">
      <path d="M55,27 L27,55 M55,55 L0,55 L0,27" stroke="#d4af37" stroke-width="2" fill="none"/>
    </svg>
    
    <!-- 内容区域 -->
    <div class="absolute inset-0 flex flex-col items-center justify-center z-[2]">
      <div class="text-5xl font-bold text-yellow-400 mb-10 text-center" style="text-shadow: 0 0 20px rgba(255,215,0,0.5), 0 2px 10px rgba(0,0,0,0.5);">谢谢观看</div>
      <div class="text-2xl leading-relaxed font-medium text-center" style="color: #d4af37;">感谢您的聆听</div>
    </div>
  </div>
</div>
