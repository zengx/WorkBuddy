  <div class="absolute bottom-[120px] right-[150px] w-[70px] h-[70px] rotate-[10deg] border-[3px] border-[rgba(139,69,19,0.3)] flex items-center justify-center text-[16px] text-[rgba(139,69,19,0.35)] font-bold" style="font-family: serif;">谢</div>
