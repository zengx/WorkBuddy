<!-- Template: 中国风-水墨留白 (Transition #524) -->
<div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden" style="background: linear-gradient(135deg, #fdfcf8 0%, #f5f2ea 100%);">
    <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
        <!-- 水墨渲染装饰（底部） -->
        <div class="absolute bottom-0 left-0 w-full h-1/3 opacity-10" style="background: radial-gradient(ellipse at bottom, #1a1a1a 0%, transparent 60%);"></div>
        
        <!-- 飞鸟装饰（左上） -->
        <div class="absolute top-20 left-16 opacity-25">
            <svg width="50" height="25" viewBox="0 0 60 30">
                <path d="M10,15 Q20,10 30,15 Q20,12 10,15" stroke="#2d2d2d" stroke-width="1.5" fill="none"/>
                <path d="M35,18 Q45,13 55,18 Q45,15 35,18" stroke="#2d2d2d" stroke-width="1.5" fill="none"/>
            </svg>
        </div>
        
        <!-- 中央内容区 -->
        <div class="flex items-center justify-center h-full">
            <div class="text-center z-10 px-20">
                <!-- 章节标识 -->
                <div class="mb-8">
                    <div class="inline-flex items-center gap-3">
                        <div class="w-6 h-px bg-gray-400"></div>
                        <span class="text-lg tracking-widest" style="color: #8b4513; font-family: 'KaiTi', serif;">第一章</span>
                        <div class="w-6 h-px bg-gray-400"></div>
                    </div>
                </div>
                
                <!-- 主标题 -->
                <h1 class="text-5xl font-bold mb-6 tracking-wide" style="color: #2d2d2d; font-family: 'KaiTi', serif; line-height: 1.3;">项目背景</h1>
                
                <!-- 副标题 -->
                <p class="text-lg tracking-wide" style="color: #888; font-family: 'KaiTi', serif;">了解项目的起源与目标</p>
            </div>
        </div>
        
        <!-- 印章装饰（右下角） -->
        <div class="absolute bottom-16 right-16 w-14 h-14 opacity-60 transform rotate-12" style="background: linear-gradient(135deg, #c41e3a 0%, #8b1428 100%); clip-path: polygon(8% 0%, 92% 0%, 100% 8%, 100% 92%, 92% 100%, 8% 100%, 0% 92%, 0% 8%);">
            <div class="w-full h-full flex items-center justify-center">
                <span class="text-xs text-white font-bold" style="font-family: 'KaiTi', serif;">墨</span>
            </div>
        </div>
        
        <!-- 细微装饰点 -->
        <div class="absolute top-1/3 right-1/4 w-1 h-1 rounded-full bg-gray-400 opacity-50"></div>
        <div class="absolute bottom-1/3 left-1/4 w-1 h-1 rounded-full bg-gray-400 opacity-50"></div>
    </div>
</div>
