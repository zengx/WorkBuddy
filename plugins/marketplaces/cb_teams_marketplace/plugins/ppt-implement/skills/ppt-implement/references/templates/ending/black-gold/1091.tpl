<!-- Template: 黑金风-几何奢华 (Ending #1091) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: radial-gradient(circle at center, #2c2c3e 0%, #1a1a2e 100%);">
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
    <!-- 金色几何装饰 -->
    <div class="absolute -top-[72px] -left-[72px] w-[230px] h-[230px] border-3" style="transform: rotate(45deg); border-color: rgba(212,175,55,0.3);"></div>
    <div class="absolute top-[13%] -right-[90px] w-[270px] h-[270px] border-2" style="transform: rotate(30deg); border-color: rgba(255,215,0,0.25);"></div>
    <div class="absolute -bottom-[80px] left-[18%] w-[260px] h-[260px]" style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%); background: linear-gradient(135deg, rgba(212,175,55,0.15), rgba(255,215,0,0.1));"></div>
    <div class="absolute bottom-[8%] -right-[45px] w-[180px] h-[180px]" style="clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%); background: linear-gradient(135deg, rgba(218,165,32,0.12), rgba(212,175,55,0.08));"></div>
    
    <!-- 中心金色框架 -->
    <div class="absolute top-1/2 left-1/2 w-[185px] h-[185px] border-2" style="transform: translate(-50%, -50%) rotate(45deg); border-color: rgba(255,215,0,0.4);"></div>
    <div class="absolute top-1/2 left-1/2 w-[145px] h-[145px] border" style="transform: translate(-50%, -50%) rotate(45deg); border-color: rgba(212,175,55,0.3);"></div>
    
    <!-- 金色粒子装饰 -->
    <div class="absolute top-[23%] left-[18%] w-1 h-1 rounded-full bg-yellow-400 animate-[twinkle_2s_ease-in-out_infinite]" style="box-shadow: 0 0 10px #ffd700;"></div>
    <div class="absolute top-[68%] right-[20%] w-[5px] h-[5px] rounded-full animate-[twinkle_2.5s_ease-in-out_infinite_0.5s]" style="background: #d4af37; box-shadow: 0 0 8px #d4af37;"></div>
    <div class="absolute bottom-[26%] left-[26%] w-[3px] h-[3px] rounded-full bg-yellow-400 animate-[twinkle_3s_ease-in-out_infinite_1s]" style="box-shadow: 0 0 12px #ffd700;"></div>
    
    <!-- 内容区域 -->
    <div class="absolute inset-0 flex flex-col items-center justify-center z-[2]">
      <div class="text-5xl font-bold text-yellow-400 mb-10 text-center" style="text-shadow: 0 0 25px rgba(255,215,0,0.5), 0 2px 10px rgba(0,0,0,0.6);">谢谢</div>
      <div class="text-2xl leading-relaxed font-medium text-center" style="color: #d4af37;">感谢您的关注与支持</div>
    </div>
  </div>
</div>

<style>
@keyframes twinkle {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}
</style>
