<!-- Template: 扁平风-几何拼接 (Ending #1084) -->
<div class="w-[1440px] h-[810px] bg-white relative overflow-hidden">
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
    <!-- 几何拼接装饰 -->
    <div class="absolute top-0 left-0 w-0 h-0 opacity-80" style="border-left: 230px solid transparent; border-top: 230px solid #ff6b6b;"></div>
    
    <div class="absolute top-0 right-0 w-0 h-0 opacity-70" style="border-right: 260px solid transparent; border-top: 260px solid #4ecdc4;"></div>
    
    <div class="absolute bottom-0 left-0 w-0 h-0 opacity-75" style="border-left: 280px solid transparent; border-bottom: 280px solid #ffe66d;"></div>
    
    <div class="absolute bottom-0 right-0 w-0 h-0 opacity-80" style="border-right: 240px solid transparent; border-bottom: 240px solid #a8e6cf;"></div>
    
    <!-- 中心几何装饰 -->
    <div class="absolute top-1/2 left-1/2 w-[150px] h-[150px] border-3 border-indigo-400/30" style="transform: translate(-50%, -50%) rotate(45deg); background: linear-gradient(135deg, rgba(102,126,234,0.15), rgba(118,75,162,0.15));"></div>
    
    <!-- 小几何装饰 -->
    <div class="absolute top-[30%] left-[25%] w-10 h-10 bg-pink-300 opacity-60" style="transform: rotate(30deg);"></div>
    <div class="absolute top-[65%] right-[22%] w-[50px] h-[50px] bg-teal-300 opacity-70" style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"></div>
    
    <!-- 内容区域 -->
    <div class="absolute inset-0 flex flex-col items-center justify-center z-[2]">
      <div class="text-[56px] font-bold text-gray-800 mb-10">感谢</div>
      <div class="text-[28px] text-gray-700 leading-relaxed font-medium text-center">感谢您的聆听与关注</div>
    </div>
  </div>
</div>
