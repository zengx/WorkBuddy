<!-- Template: 卡通风-可爱动物 (Ending #1040) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-br from-[#fff9e6] to-[#ffe6f0]">
  <!-- 小熊装饰 - 左下 -->
  <div class="absolute bottom-[10%] left-[8%]">
    <!-- 熊头 -->
    <div class="w-[80px] h-[80px] bg-[#d4a574] rounded-full relative shadow-lg">
      <!-- 耳朵 -->
      <div class="absolute -top-[15px] left-[5px] w-[35px] h-[35px] bg-[#d4a574] rounded-full"></div>
      <div class="absolute -top-[15px] right-[5px] w-[35px] h-[35px] bg-[#d4a574] rounded-full"></div>
      <!-- 脸 -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[50px] h-[40px] bg-[#f5d9a8] rounded-full"></div>
      <!-- 眼睛 -->
      <div class="absolute top-[35%] left-[25%] w-[8px] h-[8px] bg-[#333] rounded-full"></div>
      <div class="absolute top-[35%] right-[25%] w-[8px] h-[8px] bg-[#333] rounded-full"></div>
      <!-- 鼻子 -->
      <div class="absolute bottom-[25%] left-1/2 -translate-x-1/2 w-[12px] h-[10px] bg-[#333]" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
    </div>
  </div>

  <!-- 小兔子装饰 - 右下 -->
  <div class="absolute bottom-[10%] right-[8%]">
    <!-- 兔头 -->
    <div class="w-[75px] h-[75px] bg-[#ffb3d9] rounded-full relative shadow-lg">
      <!-- 耳朵 -->
      <div class="absolute -top-[45px] left-[12px] w-[18px] h-[55px] bg-[#ffb3d9] -rotate-[15deg]" style="border-radius: 50% 50% 0 0 / 80% 80% 0 0;"></div>
      <div class="absolute -top-[45px] right-[12px] w-[18px] h-[55px] bg-[#ffb3d9] rotate-[15deg]" style="border-radius: 50% 50% 0 0 / 80% 80% 0 0;"></div>
      <!-- 眼睛 -->
      <div class="absolute top-[35%] left-[22%] w-[8px] h-[8px] bg-[#333] rounded-full"></div>
      <div class="absolute top-[35%] right-[22%] w-[8px] h-[8px] bg-[#333] rounded-full"></div>
      <!-- 鼻子 -->
      <div class="absolute bottom-[30%] left-1/2 -translate-x-1/2 w-[10px] h-[8px] bg-[#ff99cc]" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
    </div>
  </div>

  <!-- 爱心装饰 -->
  <div class="absolute top-[15%] left-[18%] text-[45px] text-[#ff99cc] animate-float">💕</div>
  <div class="absolute top-[20%] right-[20%] text-[40px] text-[#ffb3d9] animate-float-slow">💕</div>

  <!-- 气泡装饰 -->
  <div class="absolute bottom-[35%] left-[25%] w-[30px] h-[30px] border-3 border-[#66ccff] rounded-full opacity-60"></div>
  <div class="absolute bottom-[30%] right-[28%] w-[25px] h-[25px] border-3 border-[#77dd77] rounded-full opacity-60"></div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center">
    <div class="text-center max-w-[75%] mx-auto">
      <h1 class="text-[66px] text-[#ff6b9d] mb-10 font-bold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif; text-shadow: 2px 2px 0 rgba(255, 107, 157, 0.2);">感谢聆听</h1>
      
      <div class="w-[120px] h-[4px] bg-gradient-to-r from-[#ff99cc] via-[#ffb3d9] to-[#ff99cc] mx-auto mb-9 rounded-sm"></div>
      
      <p class="text-[22px] text-gray-600 leading-relaxed font-semibold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif;">期待与您再次相见</p>
    </div>
  </div>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-15px); }
    }
    .animate-float {
      animation: float 3s ease-in-out infinite;
    }
    .animate-float-slow {
      animation: float 3.5s ease-in-out infinite;
    }
  </style>
</div>
