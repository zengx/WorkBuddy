<!-- Template: 教育风格-变体9 (Content #1649) - 易错字辨析·形近字 -->
    <div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden bg-gradient-to-br from-[#fff7ed] to-[#ffedd5]">
        
        <!-- 易错字辨析布局 -->
        <div class="w-[1350px] h-[720px] mx-auto my-[20px] flex flex-col justify-center">
            <div class="text-center mb-5">
                <h1 class="text-[30px] font-bold text-orange-900 mb-1">易错字辨析 · 形近字</h1>
                <p class="text-[14px] text-orange-600">"己" vs "已" vs "巳"</p>
            </div>
            
            <div class="grid grid-cols-3 gap-5">
                <!-- 字1：己 -->
                <div class="bg-white rounded-xl shadow-lg border-2 border-orange-200 overflow-hidden">
                    <div class="bg-gradient-to-br from-red-500 to-red-600 p-2 text-white">
                        <h3 class="text-center text-[14px] font-semibold">第一个字</h3>
                    </div>
                    <div class="p-4 space-y-2">
                        <div class="w-full h-24 bg-orange-50 border-2 border-orange-300 rounded-xl flex items-center justify-center relative">
                            <span class="text-[64px] font-serif text-red-700 leading-none">己</span>
                            <div class="absolute bottom-1 right-1 bg-red-500 text-white text-[10px] px-1.5 py-0.5 rounded">
                                左不出头
                            </div>
                        </div>
                        
                        <div class="space-y-1.5">
                            <div class="bg-red-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-red-800 mb-0.5">读音:</p>
                                <p class="text-[18px] font-bold text-red-700">jǐ</p>
                            </div>
                            
                            <div class="bg-red-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-red-800 mb-0.5">意思:</p>
                                <p class="text-[12px] text-gray-700">自己、自身</p>
                            </div>
                            
                            <div class="bg-red-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-red-800 mb-0.5">组词:</p>
                                <div class="flex flex-wrap gap-1">
                                    <span class="px-1.5 py-0.5 bg-white border border-red-200 rounded-full text-[12px]">自己</span>
                                    <span class="px-1.5 py-0.5 bg-white border border-red-200 rounded-full text-[12px]">知己</span>
                                    <span class="px-1.5 py-0.5 bg-white border border-red-200 rounded-full text-[12px]">克己</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- 字2：已 -->
                <div class="bg-white rounded-xl shadow-lg border-2 border-orange-200 overflow-hidden">
                    <div class="bg-gradient-to-br from-blue-500 to-blue-600 p-2 text-white">
                        <h3 class="text-center text-[14px] font-semibold">第二个字</h3>
                    </div>
                    <div class="p-4 space-y-2">
                        <div class="w-full h-24 bg-orange-50 border-2 border-orange-300 rounded-xl flex items-center justify-center relative">
                            <span class="text-[64px] font-serif text-blue-700 leading-none">已</span>
                            <div class="absolute bottom-1 right-1 bg-blue-500 text-white text-[10px] px-1.5 py-0.5 rounded">
                                左边出头
                            </div>
                        </div>
                        
                        <div class="space-y-1.5">
                            <div class="bg-blue-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-blue-800 mb-0.5">读音:</p>
                                <p class="text-[18px] font-bold text-blue-700">yǐ</p>
                            </div>
                            
                            <div class="bg-blue-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-blue-800 mb-0.5">意思:</p>
                                <p class="text-[12px] text-gray-700">已经、停止</p>
                            </div>
                            
                            <div class="bg-blue-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-blue-800 mb-0.5">组词:</p>
                                <div class="flex flex-wrap gap-1">
                                    <span class="px-1.5 py-0.5 bg-white border border-blue-200 rounded-full text-[12px]">已经</span>
                                    <span class="px-1.5 py-0.5 bg-white border border-blue-200 rounded-full text-[12px]">早已</span>
                                    <span class="px-1.5 py-0.5 bg-white border border-blue-200 rounded-full text-[12px]">已知</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- 字3：巳 -->
                <div class="bg-white rounded-xl shadow-lg border-2 border-orange-200 overflow-hidden">
                    <div class="bg-gradient-to-br from-green-500 to-green-600 p-2 text-white">
                        <h3 class="text-center text-[14px] font-semibold">第三个字</h3>
                    </div>
                    <div class="p-4 space-y-2">
                        <div class="w-full h-24 bg-orange-50 border-2 border-orange-300 rounded-xl flex items-center justify-center relative">
                            <span class="text-[64px] font-serif text-green-700 leading-none">巳</span>
                            <div class="absolute bottom-1 right-1 bg-green-500 text-white text-[10px] px-1.5 py-0.5 rounded">
                                全部出头
                            </div>
                        </div>
                        
                        <div class="space-y-1.5">
                            <div class="bg-green-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-green-800 mb-0.5">读音:</p>
                                <p class="text-[18px] font-bold text-green-700">sì</p>
                            </div>
                            
                            <div class="bg-green-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-green-800 mb-0.5">意思:</p>
                                <p class="text-[12px] text-gray-700">地支第六位(蛇)</p>
                            </div>
                            
                            <div class="bg-green-50 p-2 rounded-lg">
                                <p class="text-[10px] font-semibold text-green-800 mb-0.5">组词:</p>
                                <div class="flex flex-wrap gap-1">
                                    <span class="px-1.5 py-0.5 bg-white border border-green-200 rounded-full text-[12px]">巳时</span>
                                    <span class="px-1.5 py-0.5 bg-white border border-green-200 rounded-full text-[12px]">巳蛇</span>
                                    <span class="px-1.5 py-0.5 bg-white border border-green-200 rounded-full text-[12px]">己巳年</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 记忆口诀 -->
            <div class="mt-5 bg-gradient-to-r from-orange-100 via-amber-100 to-yellow-100 border-2 border-orange-300 rounded-xl p-4">
                <h3 class="text-[16px] font-bold text-orange-900 mb-2 text-center flex items-center justify-center">
                    <span class="text-[18px] mr-2">🎯</span>
                    记忆口诀
                    <span class="text-[18px] ml-2">🎯</span>
                </h3>
                <p class="text-[16px] font-serif text-center text-orange-800 leading-relaxed">
                    左不出头是<span class="font-bold text-red-700 text-[18px] mx-1">己</span>自己，
                    左边出头是<span class="font-bold text-blue-700 text-[18px] mx-1">已</span>已经，
                    全都出头是<span class="font-bold text-green-700 text-[18px] mx-1">巳</span>巳蛇。
                </p>
            </div>
        </div>
    </div>
