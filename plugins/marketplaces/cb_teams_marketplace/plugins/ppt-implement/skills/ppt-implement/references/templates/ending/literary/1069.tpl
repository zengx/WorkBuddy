<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);">
  <!-- 水彩晕染效果 -->
  <div class="absolute top-[-100px] left-[-100px] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(255,182,193,0.3) 0%, transparent 70%); filter: blur(40px);"></div>
  <div class="absolute top-1/2 right-[-120px] w-[450px] h-[450px] rounded-full" style="background: radial-gradient(circle, rgba(176,224,230,0.25) 0%, transparent 70%); filter: blur(45px);"></div>
  <div class="absolute bottom-[-80px] left-[20%] w-[380px] h-[380px] rounded-full" style="background: radial-gradient(circle, rgba(255,218,185,0.28) 0%, transparent 70%); filter: blur(35px);"></div>
  
  <!-- 手绘线条装饰 -->
  <svg class="absolute top-[15%] left-[10%] w-[120px] h-[80px] opacity-40" xmlns="http://www.w3.org/2000/svg">
    <path d="M10,40 Q40,10 70,30 T110,50" fill="none" stroke="#d4a373" stroke-width="2" stroke-linecap="round"/>
    <path d="M15,55 Q35,70 65,60 T105,65" fill="none" stroke="#d4a373" stroke-width="2" stroke-linecap="round"/>
  </svg>
  
  <svg class="absolute bottom-[18%] right-[12%] w-[100px] h-[70px] opacity-40" xmlns="http://www.w3.org/2000/svg">
    <path d="M10,30 Q30,10 50,25 T90,40" fill="none" stroke="#d4a373" stroke-width="2" stroke-linecap="round"/>
  </svg>
  
  <!-- 内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col items-center justify-center relative z-[2]">
    <h1 class="text-[56px] font-light text-[#8b6f47] mb-[40px]" style="font-family: 'Georgia', serif; text-shadow: 0 2px 8px rgba(255,255,255,0.5);">谢谢观看</h1>
    <p class="text-[28px] text-[#a67c52] font-light leading-[1.8]" style="font-family: 'Georgia', serif;">感谢您的聆听</p>
  </div>
  
  <!-- 小花朵装饰 -->
  <div class="absolute top-[25%] left-[18%] w-[25px] h-[25px] rounded-full bg-[rgba(255,182,193,0.4)]" style="animation: float 3s ease-in-out infinite;"></div>
  <div class="absolute top-[28%] left-[20%] w-[20px] h-[20px] rounded-full bg-[rgba(255,182,193,0.35)]" style="animation: float 3.2s ease-in-out infinite 0.3s;"></div>
  <div class="absolute bottom-[22%] right-[15%] w-[22px] h-[22px] rounded-full bg-[rgba(176,224,230,0.4)]" style="animation: float 3.5s ease-in-out infinite 0.6s;"></div>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0) scale(1); opacity: 0.4; }
      50% { transform: translateY(-15px) scale(1.1); opacity: 0.6; }
    }
  </style>
</div>
