<!-- Template: 卡通风-贴纸拼贴 (Ending #1045) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-br from-[#fef9e7] to-[#fce4ec]">
  <!-- 贴纸样式 - 左上角星星 -->
  <div class="absolute top-[8%] left-[8%] w-[100px] h-[100px] bg-[#ffea5c] shadow-lg -rotate-[15deg]" style="clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);"></div>

  <!-- 贴纸样式 - 右上角爱心 -->
  <div class="absolute top-[12%] right-[10%] w-[90px] h-[90px] rotate-[15deg]">
    <div class="absolute w-[50px] h-[80px] bg-[#ff6b9d] left-[25px] shadow-lg origin-bottom-left -rotate-[45deg]" style="border-radius: 50px 50px 0 0;"></div>
    <div class="absolute w-[50px] h-[80px] bg-[#ff6b9d] left-[15px] shadow-lg origin-bottom-right rotate-[45deg]" style="border-radius: 50px 50px 0 0;"></div>
  </div>

  <!-- 贴纸样式 - 左下圆形 -->
  <div class="absolute bottom-[12%] left-[12%] w-[95px] h-[95px] bg-[#77dd77] rounded-full shadow-lg -rotate-[10deg] flex items-center justify-center text-[32px] text-white font-bold" style="font-family: 'Comic Sans MS', sans-serif;">👍</div>

  <!-- 贴纸样式 - 右下三角形 -->
  <div class="absolute bottom-[15%] right-[15%] w-0 h-0 shadow-lg rotate-[20deg] border-l-[50px] border-r-[50px] border-b-[90px] border-l-transparent border-r-transparent border-b-[#b388ff]"></div>

  <!-- 贴纸样式 - 小星星装饰 -->
  <div class="absolute top-[28%] left-[25%] w-[40px] h-[40px] bg-[#ffb347] shadow-md rotate-[25deg]" style="clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);"></div>
  <div class="absolute bottom-[32%] right-[28%] w-[45px] h-[45px] bg-[#66ccff] shadow-md -rotate-[20deg]" style="clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);"></div>

  <!-- 虚线装饰 -->
  <div class="absolute top-[35%] left-[18%] w-[100px] h-[2px] -rotate-[25deg]" style="background: repeating-linear-gradient(90deg, #ff6b9d, #ff6b9d 10px, transparent 10px, transparent 20px);"></div>
  <div class="absolute bottom-[40%] right-[20%] w-[120px] h-[2px] rotate-[20deg]" style="background: repeating-linear-gradient(90deg, #77dd77, #77dd77 10px, transparent 10px, transparent 20px);"></div>

  <!-- 主要内容区域 -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70%] px-[40px] py-[50px] bg-white/80 rounded-[30px] shadow-2xl backdrop-blur-sm">
    <h1 class="text-[66px] text-[#ff6b9d] mb-10 font-bold text-center" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif; text-shadow: 2px 2px 0 rgba(255, 107, 157, 0.15);">谢谢</h1>
    
    <div class="flex items-center justify-center gap-[10px] mb-8">
      <div class="w-[15px] h-[15px] bg-[#ffea5c] rotate-45"></div>
      <div class="w-[15px] h-[15px] bg-[#ff6b9d] rounded-full"></div>
      <div class="w-[15px] h-[15px] bg-[#77dd77]" style="clip-path: polygon(50% 0%, 100% 100%, 0% 100%);"></div>
      <div class="w-[15px] h-[15px] bg-[#b388ff] rounded-full"></div>
      <div class="w-[15px] h-[15px] bg-[#66ccff] rotate-45"></div>
    </div>
    
    <p class="text-[22px] text-gray-600 leading-relaxed text-center font-semibold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif;">感谢您的宝贵时间</p>
  </div>
</div>
