<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: linear-gradient(to bottom, #1a2332 0%, #2d3e5f 50%, #3a5278 100%);">
  <!-- 月亮 -->
  <div class="absolute top-[15%] right-[15%] w-[120px] h-[120px] rounded-full opacity-90" style="background: radial-gradient(circle at 30% 30%, #fef9e7, #f4e4c1); box-shadow: 0 0 40px rgba(254,249,231,0.5), 0 0 80px rgba(254,249,231,0.3);"></div>
  
  <!-- 月光光晕 -->
  <div class="absolute top-[15%] right-[15%] w-[120px] h-[120px] rounded-full scale-[2]" style="background: radial-gradient(circle, rgba(254,249,231,0.15) 0%, transparent 70%); filter: blur(20px);"></div>
  
  <!-- 星星装饰 -->
  <div class="absolute top-[12%] left-[20%] w-[3px] h-[3px] rounded-full bg-white" style="box-shadow: 0 0 8px rgba(255,255,255,0.8); animation: twinkle 2s ease-in-out infinite;"></div>
  <div class="absolute top-[25%] left-[15%] w-[2px] h-[2px] rounded-full bg-white" style="box-shadow: 0 0 6px rgba(255,255,255,0.7); animation: twinkle 2.5s ease-in-out infinite 0.5s;"></div>
  <div class="absolute top-[30%] left-[30%] w-[2.5px] h-[2.5px] rounded-full bg-white" style="box-shadow: 0 0 7px rgba(255,255,255,0.75); animation: twinkle 3s ease-in-out infinite 1s;"></div>
  <div class="absolute top-[18%] left-[40%] w-[2px] h-[2px] rounded-full bg-white" style="box-shadow: 0 0 6px rgba(255,255,255,0.7); animation: twinkle 2.8s ease-in-out infinite 1.5s;"></div>
  <div class="absolute top-[35%] right-[25%] w-[3px] h-[3px] rounded-full bg-white" style="box-shadow: 0 0 8px rgba(255,255,255,0.8); animation: twinkle 2.3s ease-in-out infinite 0.8s;"></div>
  <div class="absolute bottom-[35%] left-[18%] w-[2.5px] h-[2.5px] rounded-full bg-white" style="box-shadow: 0 0 7px rgba(255,255,255,0.75); animation: twinkle 2.7s ease-in-out infinite 1.2s;"></div>
  <div class="absolute bottom-[28%] right-[30%] w-[2px] h-[2px] rounded-full bg-white" style="box-shadow: 0 0 6px rgba(255,255,255,0.7); animation: twinkle 3.2s ease-in-out infinite 1.8s;"></div>
  
  <!-- 云朵装饰 -->
  <div class="absolute bottom-[20%] left-[10%] w-[150px] h-[50px] rounded-[50px] bg-[rgba(255,255,255,0.05)]" style="filter: blur(8px);"></div>
  <div class="absolute bottom-[15%] right-[12%] w-[180px] h-[60px] rounded-[60px] bg-[rgba(255,255,255,0.04)]" style="filter: blur(10px);"></div>
  
  <!-- 内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col items-center justify-center relative z-[2]">
    <h1 class="text-[56px] font-light text-[#e8dcc8] mb-[40px]" style="font-family: 'Georgia', serif; text-shadow: 0 2px 15px rgba(254,249,231,0.3);">感谢聆听</h1>
    <p class="text-[28px] text-[#d4c9b8] font-light leading-[1.8]" style="font-family: 'Georgia', serif; text-shadow: 0 1px 10px rgba(254,249,231,0.2);">期待下次再见</p>
  </div>
  
  <!-- 月光诗句装饰 -->
  <div class="absolute bottom-[100px] left-1/2 -translate-x-1/2 text-[16px] text-[rgba(232,220,200,0.4)] italic tracking-[2px]" style="font-family: 'Georgia', serif;">· 月光如水 ·</div>

  <style>
    @keyframes twinkle {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.3; transform: scale(0.8); }
    }
  </style>
</div>
