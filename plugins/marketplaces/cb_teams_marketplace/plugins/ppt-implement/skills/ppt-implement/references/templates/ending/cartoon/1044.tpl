  <!-- 顶部波浪 -->
  <div class="absolute top-0 left-0 right-0 h-[100px] bg-[#ff6b9d]">
    <svg class="absolute -bottom-px left-0 w-full h-[30px]" viewBox="0 0 1200 30" preserveAspectRatio="none">
      <path d="M0,15 Q150,0 300,15 T600,15 T900,15 T1200,15 L1200,0 L0,0 Z" fill="#fff5e6"/>
    </svg>
  </div>

  <!-- 底部波浪 -->
  <div class="absolute bottom-0 left-0 right-0 h-[100px] bg-[#77dd77]">
    <svg class="absolute -top-px left-0 w-full h-[30px]" viewBox="0 0 1200 30" preserveAspectRatio="none">
      <path d="M0,15 Q150,30 300,15 T600,15 T900,15 T1200,15 L1200,30 L0,30 Z" fill="#e6f7ff"/>
    </svg>
  </div>

  <!-- 左侧波浪装饰 -->
  <div class="absolute top-[20%] left-0 w-[80px] h-[60%] bg-[#ffb347]" style="clip-path: polygon(0 0, 100% 0, 100% 10%, 90% 15%, 100% 20%, 100% 30%, 90% 35%, 100% 40%, 100% 50%, 90% 55%, 100% 60%, 100% 70%, 90% 75%, 100% 80%, 100% 90%, 90% 95%, 100% 100%, 0 100%);"></div>

  <!-- 右侧波浪装饰 -->
