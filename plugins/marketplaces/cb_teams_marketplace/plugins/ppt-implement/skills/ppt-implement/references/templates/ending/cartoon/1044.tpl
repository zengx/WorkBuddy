  <div class="absolute top-[25%] right-[18%] w-[30px] h-[30px] bg-[#66ccff] rounded-full shadow-md"></div>
  <div class="absolute bottom-[25%] left-[20%] w-[28px] h-[28px] bg-[#ff99cc] rounded-full shadow-md"></div>
  <div class="absolute bottom-[20%] right-[22%] w-[26px] h-[26px] bg-[#ffb347] rounded-full shadow-md"></div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center">
    <div class="text-center max-w-[70%] mx-auto">
