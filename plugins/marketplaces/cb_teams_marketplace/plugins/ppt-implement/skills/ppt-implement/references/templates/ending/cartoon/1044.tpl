      <div class="flex items-center justify-center gap-4 mb-9">
        <div class="w-[60px] h-[4px] bg-[#ffb347] rounded-sm"></div>
        <div class="w-[20px] h-[20px] bg-[#ff6b9d] rounded-full"></div>
        <div class="w-[60px] h-[4px] bg-[#77dd77] rounded-sm"></div>
      </div>
      
      <p class="text-[24px] text-gray-600 leading-relaxed font-semibold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif;">感谢您的聆听与关注</p>
    </div>
