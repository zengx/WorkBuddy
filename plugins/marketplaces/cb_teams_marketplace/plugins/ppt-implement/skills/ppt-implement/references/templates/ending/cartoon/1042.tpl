<!-- Template: 卡通风-笑脸表情 (Ending #1042) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-b from-[#fffacd] to-[#fff0f5]">
  <!-- 大笑脸 - 中心 -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[250px] h-[250px] rounded-full shadow-2xl z-[1] bg-gradient-to-br from-[#ffea5c] to-[#ffd700]">
    <!-- 眼睛 -->
    <div class="absolute top-[35%] left-[28%] w-[18px] h-[25px] bg-[#333] rounded-full -rotate-[15deg]"></div>
    <div class="absolute top-[35%] right-[28%] w-[18px] h-[25px] bg-[#333] rounded-full rotate-[15deg]"></div>
    
    <!-- 笑脸 -->
    <div class="absolute bottom-[25%] left-1/2 -translate-x-1/2 w-[120px] h-[60px] border-5 border-[#333] border-t-0 rounded-b-[60px]"></div>
    
    <!-- 脸红 -->
    <div class="absolute top-1/2 left-[10%] w-[30px] h-[20px] bg-red-400/40 rounded-full"></div>
    <div class="absolute top-1/2 right-[10%] w-[30px] h-[20px] bg-red-400/40 rounded-full"></div>
  </div>

  <!-- 小笑脸装饰 -->
  <div class="absolute top-[15%] left-[15%] w-[60px] h-[60px] bg-[#ffb347] rounded-full shadow-lg">
    <div class="absolute top-[35%] left-[28%] w-[6px] h-[6px] bg-[#333] rounded-full"></div>
    <div class="absolute top-[35%] right-[28%] w-[6px] h-[6px] bg-[#333] rounded-full"></div>
    <div class="absolute bottom-[25%] left-1/2 -translate-x-1/2 w-[30px] h-[15px] border-2 border-[#333] border-t-0 rounded-b-[15px]"></div>
  </div>

  <div class="absolute top-[20%] right-[18%] w-[55px] h-[55px] bg-[#ff99cc] rounded-full shadow-lg">
    <div class="absolute top-[35%] left-[28%] w-[5px] h-[5px] bg-[#333] rounded-full"></div>
    <div class="absolute top-[35%] right-[28%] w-[5px] h-[5px] bg-[#333] rounded-full"></div>
    <div class="absolute bottom-[28%] left-1/2 -translate-x-1/2 w-[28px] h-[14px] border-2 border-[#333] border-t-0 rounded-b-[14px]"></div>
  </div>

  <div class="absolute bottom-[18%] left-[20%] w-[50px] h-[50px] bg-[#77dd77] rounded-full shadow-lg">
    <div class="absolute top-[35%] left-[28%] w-[5px] h-[5px] bg-[#333] rounded-full"></div>
    <div class="absolute top-[35%] right-[28%] w-[5px] h-[5px] bg-[#333] rounded-full"></div>
    <div class="absolute bottom-[28%] left-1/2 -translate-x-1/2 w-[25px] h-[12px] border-2 border-[#333] border-t-0 rounded-b-[12px]"></div>
  </div>

  <div class="absolute bottom-[15%] right-[22%] w-[58px] h-[58px] bg-[#b388ff] rounded-full shadow-lg">
    <div class="absolute top-[35%] left-[28%] w-[5px] h-[5px] bg-[#333] rounded-full"></div>
    <div class="absolute top-[35%] right-[28%] w-[5px] h-[5px] bg-[#333] rounded-full"></div>
    <div class="absolute bottom-[28%] left-1/2 -translate-x-1/2 w-[28px] h-[14px] border-2 border-[#333] border-t-0 rounded-b-[14px]"></div>
  </div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col">
    <div class="text-center max-w-[75%] mx-auto mt-[50px] relative z-[2]">
      <h1 class="text-[64px] text-[#ff6b6b] mb-4 font-bold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif; text-shadow: 3px 3px 0 rgba(255, 107, 107, 0.2);">致谢</h1>
      
      <p class="text-[22px] text-gray-600 leading-relaxed font-semibold" style="font-family: 'Comic Sans MS', 'Arial Rounded MT Bold', sans-serif;">欢迎交流与指导</p>
    </div>
  </div>
</div>
