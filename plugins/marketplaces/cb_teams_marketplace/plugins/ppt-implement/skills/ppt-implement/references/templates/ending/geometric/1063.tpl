<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: linear-gradient(135deg, #2d3561 0%, #c05c7e 100%);">
  <!-- 矩形装饰 -->
  <div class="absolute top-[-50px] left-[-80px] w-[250px] h-[180px] -rotate-[15deg] bg-[rgba(255,255,255,0.08)]"></div>
  <div class="absolute top-[20%] right-[-60px] w-[200px] h-[280px] rotate-[20deg] bg-[rgba(255,255,255,0.1)]"></div>
  <div class="absolute bottom-[-80px] left-[10%] w-[300px] h-[200px] rotate-[10deg] bg-[rgba(255,255,255,0.12)]"></div>
  <div class="absolute bottom-[15%] right-[-50px] w-[220px] h-[160px] -rotate-[25deg] bg-[rgba(255,255,255,0.09)]"></div>
  
  <!-- 中心矩形框架 -->
  <div class="absolute top-1/2 left-1/2 w-[400px] h-[250px] border-[3px] border-[rgba(255,255,255,0.3)]" style="transform: translate(-50%, -50%) rotate(5deg);"></div>
  <div class="absolute top-1/2 left-1/2 w-[350px] h-[220px] border-2 border-[rgba(255,255,255,0.25)]" style="transform: translate(-50%, -50%) rotate(-5deg);"></div>
  
  <!-- 内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col items-center justify-center relative z-[2]">
    <h1 class="text-[56px] font-bold text-white mb-[40px]" style="font-family: 'Arial', 'Microsoft YaHei', sans-serif; text-shadow: 0 2px 10px rgba(0,0,0,0.3);">谢谢观看</h1>
    <p class="text-[28px] text-[rgba(255,255,255,0.95)] leading-[1.6]" style="font-family: 'Arial', 'Microsoft YaHei', sans-serif;">期待您的宝贵意见</p>
  </div>
  
  <!-- 小矩形装饰 -->
  <div class="absolute top-[15%] left-[12%] w-[60px] h-[60px] rotate-[25deg] bg-[rgba(255,255,255,0.2)]" style="animation: rotate-slow 10s linear infinite;"></div>
  <div class="absolute top-[70%] right-[15%] w-[50px] h-[50px] -rotate-[30deg] bg-[rgba(255,255,255,0.18)]" style="animation: rotate-slow 12s linear infinite reverse;"></div>

  <style>
    @keyframes rotate-slow {
      from { transform: rotate(25deg); }
      to { transform: rotate(385deg); }
    }
  </style>
</div>
