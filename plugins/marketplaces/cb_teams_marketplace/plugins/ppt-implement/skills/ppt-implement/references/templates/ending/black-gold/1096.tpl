<!-- Template: 黑金风-钻石切割 (Ending #1096) -->
<div class="w-[1440px] h-[810px] bg-gradient-to-br from-slate-900 to-indigo-900 relative overflow-hidden">
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
    <!-- 钻石切割装饰 -->
    <div class="absolute top-[12%] left-[12%] w-[110px] h-[90px] animate-[diamond-shine_3s_ease-in-out_infinite]" style="clip-path: polygon(50% 0%, 100% 35%, 75% 100%, 25% 100%, 0% 35%); background: linear-gradient(135deg, rgba(255,215,0,0.3), rgba(212,175,55,0.2), rgba(255,215,0,0.3)); box-shadow: 0 10px 30px rgba(255,215,0,0.3);"></div>
    
    <div class="absolute top-[58%] right-[10%] w-[130px] h-[105px] animate-[diamond-shine_3.5s_ease-in-out_infinite_0.5s]" style="clip-path: polygon(50% 0%, 100% 35%, 75% 100%, 25% 100%, 0% 35%); background: linear-gradient(135deg, rgba(218,165,32,0.3), rgba(255,215,0,0.25), rgba(212,175,55,0.3)); box-shadow: 0 10px 30px rgba(212,175,55,0.3);"></div>
    
    <div class="absolute bottom-[18%] left-[18%] w-[90px] h-[75px] animate-[diamond-shine_4s_ease-in-out_infinite_1s]" style="clip-path: polygon(50% 0%, 100% 35%, 75% 100%, 25% 100%, 0% 35%); background: linear-gradient(135deg, rgba(255,215,0,0.25), rgba(218,165,32,0.2), rgba(255,215,0,0.25)); box-shadow: 0 10px 30px rgba(218,165,32,0.3);"></div>
    
    <!-- 切割线条 -->
    <svg class="absolute top-0 left-0 w-full h-full opacity-15" xmlns="http://www.w3.org/2000/svg">
      <line x1="0" y1="0" x2="100%" y2="100%" stroke="#ffd700" stroke-width="1"/>
      <line x1="100%" y1="0" x2="0" y2="100%" stroke="#d4af37" stroke-width="1"/>
      <line x1="50%" y1="0" x2="50%" y2="100%" stroke="#ffd700" stroke-width="0.5"/>
      <line x1="0" y1="50%" x2="100%" y2="50%" stroke="#d4af37" stroke-width="0.5"/>
    </svg>
    
    <!-- 中心钻石 -->
    <div class="absolute top-1/2 left-1/2 w-[170px] h-[140px] border-2" style="transform: translate(-50%, -50%); clip-path: polygon(50% 0%, 100% 35%, 75% 100%, 25% 100%, 0% 35%); background: linear-gradient(135deg, rgba(255,215,0,0.2), transparent, rgba(212,175,55,0.2)); border-color: rgba(255,215,0,0.4);"></div>
    
    <!-- 内容区域 -->
    <div class="absolute inset-0 flex flex-col items-center justify-center z-[2]">
      <div class="text-5xl font-bold text-yellow-400 mb-10 text-center" style="text-shadow: 0 0 30px rgba(255,215,0,0.8), 0 2px 10px rgba(0,0,0,0.8);">谢谢观看</div>
      <div class="text-2xl leading-relaxed font-medium text-center" style="color: #d4af37;">欢迎提出宝贵建议</div>
    </div>
    
    <!-- 闪光点 -->
    <div class="absolute top-[28%] left-[28%] w-1.5 h-1.5 rounded-full bg-white animate-[twinkle-bright_2s_ease-in-out_infinite]" style="box-shadow: 0 0 20px #ffd700;"></div>
    <div class="absolute bottom-[38%] right-[33%] w-2 h-2 rounded-full bg-white animate-[twinkle-bright_2.5s_ease-in-out_infinite_0.7s]" style="box-shadow: 0 0 25px #ffd700;"></div>
  </div>
</div>

<style>
@keyframes diamond-shine {
  0%, 100% { opacity: 1; filter: brightness(1); }
  50% { opacity: 0.8; filter: brightness(1.3); }
}
@keyframes twinkle-bright {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(1.5); }
}
</style>
