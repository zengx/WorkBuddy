<!-- Template: 卡通风-对话框 (Ending #1043) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-br from-[#e6f7ff] to-[#fff0f5]">
  <!-- 大对话框 - 中心 -->
