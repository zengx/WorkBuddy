<div class="w-[1440px] h-[810px] relative overflow-hidden" style="background: linear-gradient(to bottom, #faf8f3 0%, #f5f0e8 100%);">
  <!-- 淡雅装饰线 -->
  <div class="absolute top-[30%] left-[15%] w-[150px] h-[1px] opacity-50" style="background: linear-gradient(90deg, transparent, #d4c5b0, transparent);"></div>
  <div class="absolute bottom-[35%] right-[18%] w-[180px] h-[1px] opacity-50" style="background: linear-gradient(90deg, transparent, #d4c5b0, transparent);"></div>
  
  <!-- 简约圆形装饰 -->
  <div class="absolute top-[20%] left-[12%] w-[40px] h-[40px] rounded-full border border-[rgba(180,160,130,0.25)]"></div>
  <div class="absolute top-[22%] left-[14%] w-[20px] h-[20px] rounded-full bg-[rgba(180,160,130,0.1)]"></div>
  
  <div class="absolute bottom-[25%] right-[15%] w-[50px] h-[50px] rounded-full border border-[rgba(180,160,130,0.3)]"></div>
  <div class="absolute bottom-[27%] right-[17%] w-[25px] h-[25px] rounded-full bg-[rgba(180,160,130,0.12)]"></div>
  
  <!-- 文字装饰元素 -->
  <svg class="absolute top-[18%] right-[20%] w-[60px] h-[60px] opacity-20" xmlns="http://www.w3.org/2000/svg">
    <text x="30" y="40" font-size="40" text-anchor="middle" fill="#b4a082" font-family="serif" font-style="italic">"</text>
  </svg>
  
  <svg class="absolute bottom-[28%] left-[22%] w-[60px] h-[60px] opacity-20" xmlns="http://www.w3.org/2000/svg">
    <text x="30" y="40" font-size="40" text-anchor="middle" fill="#b4a082" font-family="serif" font-style="italic">"</text>
  </svg>
  
  <!-- 内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col items-center justify-center relative z-[2] px-[100px]">
    <h1 class="text-[56px] font-light text-[#7d6e5f] mb-[50px] tracking-[3px]" style="font-family: 'Georgia', serif;">致谢</h1>
    <div class="w-[80px] h-[1px] bg-[#b4a082] mb-[40px] opacity-40"></div>
    <p class="text-[28px] text-[#a0917f] font-light leading-[2] text-center" style="font-family: 'Georgia', serif;">欢迎交流与指导</p>
  </div>
  
  <!-- 落款装饰 -->
  <div class="absolute bottom-[100px] right-[120px] flex items-center gap-[10px] opacity-30">
    <div class="w-[30px] h-[1px] bg-[#b4a082]"></div>
    <div class="w-[6px] h-[6px] rounded-full bg-[#b4a082]"></div>
  </div>
</div>
