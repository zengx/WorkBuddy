<!-- Template: 中国风-莲花禅意 (Ending #1037) -->
<div class="w-[1440px] h-[810px] relative overflow-hidden bg-gradient-to-b from-[#f8f8f0] to-[#e8e8d8]">
  <!-- 水波纹 -->
  <div class="absolute bottom-0 left-0 right-0 h-[40%] bg-gradient-to-t from-[#8b7355]/8 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-[2px]" style="background: repeating-linear-gradient(90deg, transparent, transparent 20px, rgba(139, 115, 85, 0.2) 20px, rgba(139, 115, 85, 0.2) 40px);"></div>

  <!-- 莲花装饰 - 左下 -->
  <div class="absolute bottom-[15%] left-[12%] z-0 pointer-events-none">
    <div class="relative w-[100px] h-[100px]">
      <!-- 莲花瓣 -->
      <div class="absolute w-[35px] h-[60px] bg-gradient-to-t from-[#c8a882] to-[#e8c8a2] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 origin-bottom" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
      <div class="absolute w-[35px] h-[60px] bg-gradient-to-t from-[#c8a882] to-[#e8c8a2] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-[72deg] origin-bottom" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
      <div class="absolute w-[35px] h-[60px] bg-gradient-to-t from-[#c8a882] to-[#e8c8a2] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-[144deg] origin-bottom" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
      <div class="absolute w-[35px] h-[60px] bg-gradient-to-t from-[#c8a882] to-[#e8c8a2] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-[216deg] origin-bottom" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
      <div class="absolute w-[35px] h-[60px] bg-gradient-to-t from-[#c8a882] to-[#e8c8a2] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-[288deg] origin-bottom" style="border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;"></div>
      <!-- 莲花中心 -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[25px] h-[25px] rounded-full" style="background: radial-gradient(circle, #f5d908, #e8c808);"></div>
    </div>
  </div>

  <!-- 荷叶装饰 - 右下 -->
  <div class="absolute bottom-[18%] right-[15%] w-[120px] h-[120px] rounded-full border-2 border-[#8b7355]/20 z-0 pointer-events-none" style="background: radial-gradient(circle, rgba(139, 115, 85, 0.15) 0%, transparent 70%);">
    <div class="absolute top-0 left-1/2 w-[2px] h-[50%] bg-gradient-to-b from-[#8b7355]/30 to-transparent -translate-x-1/2"></div>
  </div>

  <!-- 禅意圆圈 -->
  <div class="absolute top-[15%] right-[15%] w-[100px] h-[100px] border-3 border-[#8b7355]/30 rounded-full rotate-45 border-t-transparent border-r-transparent z-0 pointer-events-none"></div>

  <!-- 主要内容区域 -->
  <div class="w-[1350px] h-[720px] mx-auto my-[45px] flex flex-col justify-center relative z-10">
    <div class="text-center max-w-[75%] mx-auto" style="margin-top: -40px;">
      <h1 class="text-[68px] text-[#2c2c2c] mb-10 font-normal tracking-[10px]" style="font-family: 'STKaiti', 'KaiTi', serif;">谢谢观看</h1>
      
      <div class="flex items-center justify-center gap-4 mb-9">
        <div class="w-[10px] h-[10px] bg-[#c8a882] rounded-full"></div>
        <div class="w-[60px] h-px bg-[#8b7355]"></div>
        <div class="w-[16px] h-[16px] rounded-full" style="background: radial-gradient(circle, #f5d908, #e8c808);"></div>
        <div class="w-[60px] h-px bg-[#8b7355]"></div>
        <div class="w-[10px] h-[10px] bg-[#c8a882] rounded-full"></div>
      </div>
      
      <p class="text-[22px] text-gray-600 leading-relaxed tracking-[2px]" style="font-family: 'STKaiti', 'KaiTi', serif;">期待您的宝贵意见</p>
    </div>
  </div>
</div>
