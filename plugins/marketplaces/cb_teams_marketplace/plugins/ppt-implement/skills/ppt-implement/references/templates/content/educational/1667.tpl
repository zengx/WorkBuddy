<!-- Template: 教育风格-变体27 (Content #1667) - 数字与数学·认识时钟 -->
<div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden bg-gradient-to-br from-[#f8fafc] to-[#f1f5f9]">
    
    <!-- 内容填充区域 -->
    <div class="w-[1350px] h-[720px] mx-auto my-[20px] flex flex-col">
        
        <!-- 标题区 -->
        <div class="text-center pt-4 pb-5">
            <h1 class="text-[38px] font-bold text-slate-800 mb-2">认识时钟 ⏰</h1>
            <p class="text-[18px] text-slate-500">学会看时间</p>
        </div>
        
        <!-- 主内容区 -->
        <div class="grid grid-cols-2 gap-8 px-6 flex-1">
            
            <!-- 左侧：时钟展示 -->
            <div class="flex items-center justify-center">
                <div class="relative w-80 h-80 bg-white rounded-full border-[6px] border-slate-300 shadow-lg">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-full h-full relative">
                            <div class="absolute top-3 left-1/2 transform -translate-x-1/2 text-[28px] font-bold text-slate-700">12</div>
                            <div class="absolute bottom-3 left-1/2 transform -translate-x-1/2 text-[28px] font-bold text-slate-700">6</div>
                            <div class="absolute left-3 top-1/2 transform -translate-y-1/2 text-[28px] font-bold text-slate-700">9</div>
                            <div class="absolute right-3 top-1/2 transform -translate-y-1/2 text-[28px] font-bold text-slate-700">3</div>
                            <div class="absolute w-1 h-24 bg-slate-700 origin-bottom rounded-full" style="top: 50%; left: 50%; transform: translate(-50%, -100%) rotate(90deg);"></div>
                            <div class="absolute w-0.5 h-32 bg-rose-500 origin-bottom rounded-full" style="top: 50%; left: 50%; transform: translate(-50%, -100%);"></div>
                            <div class="absolute w-3 h-3 bg-slate-700 rounded-full top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- 右侧：说明区 -->
            <div class="space-y-4">
                <div class="bg-white rounded-xl border border-slate-200 p-5">
                    <h3 class="text-[20px] font-bold text-slate-800 mb-4 flex items-center">
                        <span class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center mr-3">📍</span>
                        时针与分针
                    </h3>
                    <div class="space-y-3">
                        <div class="flex items-center p-3 bg-slate-50 rounded-lg">
                            <div class="w-12 h-2 bg-slate-700 rounded mr-4"></div>
                            <div>
                                <p class="font-bold text-slate-800 text-[16px]">短针 = 时针</p>
                                <p class="text-[14px] text-slate-500">指向几就是几点</p>
                            </div>
                        </div>
                        <div class="flex items-center p-3 bg-rose-50 rounded-lg">
                            <div class="w-20 h-1.5 bg-rose-500 rounded mr-4"></div>
                            <div>
                                <p class="font-bold text-rose-700 text-[16px]">长针 = 分针</p>
                                <p class="text-[14px] text-slate-500">走一圈是60分钟</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-5">
                    <h3 class="text-[18px] font-bold text-emerald-800 mb-3">⏱️ 快速认时间</h3>
                    <div class="space-y-2 text-[14px]">
                        <div class="flex items-start"><span class="text-emerald-600 font-bold mr-2">1.</span><span class="text-slate-600">分针指向12 → 整点</span></div>
                        <div class="flex items-start"><span class="text-emerald-600 font-bold mr-2">2.</span><span class="text-slate-600">分针指向6 → 半点(30分)</span></div>
                        <div class="flex items-start"><span class="text-emerald-600 font-bold mr-2">3.</span><span class="text-slate-600">分针指向3 → 15分</span></div>
                        <div class="flex items-start"><span class="text-emerald-600 font-bold mr-2">4.</span><span class="text-slate-600">分针指向9 → 45分</span></div>
                    </div>
                </div>
                <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r-lg p-4">
                    <p class="text-amber-800 text-[14px]"><span class="font-bold">小技巧：</span>时针在2和3之间，分针指向6，就是2点30分(2点半)</p>
                </div>
            </div>
            
        </div>
        
    </div>
    
</div>
