<!-- Template: 中国风-祥云飘渺 (Transition #526) -->
<div class="w-[1440px] h-[810px] shadow-2xl relative overflow-hidden" style="background: linear-gradient(to bottom, #e6f2ff 0%, #cce0f5 50%, #f5f0e6 100%);">
    <div class="w-[1350px] h-[720px] mx-auto my-[45px] relative">
        <!-- 祥云装饰层 -->
        <div class="absolute top-10 left-10 w-40 h-20 opacity-30" style="background: radial-gradient(ellipse at center, #fff 0%, transparent 70%); border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; filter: blur(8px);"></div>
        <div class="absolute top-14 left-26 w-32 h-16 opacity-25" style="background: radial-gradient(ellipse at center, #fff 0%, transparent 70%); border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; filter: blur(6px);"></div>
        <div class="absolute top-16 left-16 w-28 h-14 opacity-20" style="background: radial-gradient(ellipse at center, #fff 0%, transparent 70%); border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; filter: blur(10px);"></div>
        
        <div class="absolute bottom-10 right-10 w-44 h-22 opacity-30" style="background: radial-gradient(ellipse at center, #fff 0%, transparent 70%); border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; filter: blur(8px);"></div>
        <div class="absolute bottom-14 right-26 w-36 h-18 opacity-25" style="background: radial-gradient(ellipse at center, #fff 0%, transparent 70%); border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; filter: blur(6px);"></div>
        
        <!-- 中央内容区 -->
        <div class="flex items-center justify-center h-full">
            <div class="text-center">
                <!-- 章节标识 -->
                <div class="mb-5 opacity-80">
                    <span class="text-xl tracking-widest" style="color: #8b4513; font-family: 'KaiTi', serif;">· 第一章 ·</span>
                </div>
                
                <!-- 主标题 -->
                <h1 class="text-6xl font-bold mb-6 tracking-wider" style="color: #2d2d2d; font-family: 'KaiTi', serif; text-shadow: 2px 2px 8px rgba(255,255,255,0.8);">项目背景</h1>
                
                <!-- 副标题 -->
                <p class="text-xl tracking-wide" style="color: #666; font-family: 'KaiTi', serif;">了解项目的起源与目标</p>
            </div>
        </div>
        
        <!-- 金色点缀 -->
        <div class="absolute top-1/3 left-1/4 w-2 h-2 rounded-full" style="background: #d4af37; opacity: 0.6;"></div>
        <div class="absolute top-2/3 right-1/4 w-2 h-2 rounded-full" style="background: #d4af37; opacity: 0.6;"></div>
        <div class="absolute top-1/2 left-1/3 w-1 h-1 rounded-full" style="background: #d4af37; opacity: 0.5;"></div>
        <div class="absolute top-1/2 right-1/3 w-1 h-1 rounded-full" style="background: #d4af37; opacity: 0.5;"></div>
        
        <!-- 印章（右下角） -->
        <div class="absolute bottom-16 right-16 w-16 h-16 opacity-60 transform rotate-8" style="background: linear-gradient(135deg, #c41e3a 0%, #8b1428 100%);">
            <div class="w-full h-full flex items-center justify-center">
                <span class="text-sm text-white font-bold" style="font-family: 'KaiTi', serif;">云</span>
            </div>
        </div>
    </div>
</div>
