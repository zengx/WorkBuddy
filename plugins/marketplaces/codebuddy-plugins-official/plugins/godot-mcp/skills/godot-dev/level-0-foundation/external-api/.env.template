# Godot MCP 外部服务配置模板
# =============================================
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 填入实际的 API Key
# 3. 确保 .env.local 已添加到 .gitignore
#
# 警告：.env.local 文件不应提交到版本控制！
# =============================================

# ===== 3D 模型生成服务 =====

# Meshy.ai - 文本到 3D 模型生成
# 官网: https://meshy.ai
# 获取 API Key: https://meshy.ai/api
MESHY_API_KEY=your_meshy_api_key_here

# Tripo3D - 高质量 3D 模型生成（备选）
# 官网: https://tripo3d.ai
TRIPO3D_API_KEY=your_tripo3d_api_key_here

# ===== 贴图/图像生成服务 =====

# Stable Diffusion API (Stability AI)
# 官网: https://stability.ai
# 获取 API Key: https://platform.stability.ai/account/keys
SD_API_KEY=your_stable_diffusion_api_key_here
SD_API_ENDPOINT=https://api.stability.ai

# Leonardo.ai - 风格化图像生成（备选）
# 官网: https://leonardo.ai
LEONARDO_API_KEY=your_leonardo_api_key_here

# ===== 音频生成服务 =====

# Suno AI - AI 音乐生成
# 官网: https://suno.ai
SUNO_API_KEY=your_suno_api_key_here

# ElevenLabs - AI 语音合成
# 官网: https://elevenlabs.io
# 获取 API Key: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===== 通用 AI 服务 =====

# OpenAI API（用于文本生成、代码辅助等）
# 官网: https://openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude API（备选）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== 服务配置 =====

# API 请求超时时间（秒）
API_TIMEOUT=60

# 失败重试次数
API_RETRY_COUNT=3

# 重试间隔（毫秒）
API_RETRY_DELAY=1000

# ===== 代理配置（可选）=====

# 如果需要通过代理访问 API
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
