{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/dist/security-guard.cjs",
            "description": "供应链安全防护 Hook，拦截依赖安装操作进行安全审计",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "write_to_file|Write|replace_in_file|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CODEBUDDY_PLUGIN_ROOT}/dist/security-guard.cjs",
            "description": "安全修复通知 Hook，向 AI 模型提供修复上下文",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
