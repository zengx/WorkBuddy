func _scan_dir(dir_path: String, expected_class: String) -> Dictionary:
	var result: Dictionary = {}
	var dir := DirAccess.open(dir_path)
	if dir == null:
		push_warning("[DataManager] Data dir not found: %s" % dir_path)
		return result

	dir.list_dir_begin()
	var file := dir.get_next()
	while file != "":
		if not dir.current_is_dir() and (file.ends_with(".tres") or file.ends_with(".res")):
			var full_path := dir_path.path_join(file)
			var res: Resource = load(full_path)
			if res == null:
				push_error("[DataManager] Failed to load %s" % full_path)
			else:
				# 先尝试读取 Resource.id 字段；没有或为空则退回文件名
				var id_raw: Variant = res.get("id") if (res as Object).has_method("get") else null
				var id: StringName
				if id_raw != null and String(id_raw) != "":
					id = StringName(String(id_raw))
				else:
					id = StringName(file.get_basename())
				if result.has(id):
					push_error("[DataManager] Duplicate %s id: %s (%s)" % [expected_class, id, full_path])
				result[id] = res
		file = dir.get_next()
	dir.list_dir_end()
	return result
