#!/usr/bin/env bash
# Wrapper for Godot data table validator.
# Works around Godot bug #88055 (exit code ignored with --script).
# Generated by godot-data-driven-config skill.
#
# Usage:
#   bash tools/validate_data.sh             # use $GODOT or auto-detect
#   GODOT=/path/to/godot bash tools/validate_data.sh
#   bash tools/validate_data.sh /path/to/godot
set -euo pipefail

GODOT_BIN="${1:-${GODOT:-godot}}"
if ! command -v "$GODOT_BIN" >/dev/null 2>&1; then
    for candidate in \
        "/Applications/Godot.app/Contents/MacOS/Godot" \
        "/Applications/Godot_mono.app/Contents/MacOS/Godot" \
        "/usr/local/bin/godot" \
        "/usr/bin/godot"; do
        if [ -x "$candidate" ]; then
            GODOT_BIN="$candidate"
            break
        fi
    done
fi
if ! command -v "$GODOT_BIN" >/dev/null 2>&1 && [ ! -x "$GODOT_BIN" ]; then
    echo "Godot executable not found. Set \$GODOT or pass path as first arg." >&2
    exit 127
fi

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

# Cold-start safety: refresh class cache if it's missing. Cheap to skip otherwise.
if [ ! -f ".godot/global_script_class_cache.cfg" ]; then
    echo "[validate] first-time setup: refreshing class cache via headless editor..."
    "$GODOT_BIN" --headless --editor --quit >/dev/null 2>&1 || true
fi

OUTPUT=$("$GODOT_BIN" --headless --quit --script res://tools/validate_data.gd 2>&1)
echo "$OUTPUT"

if echo "$OUTPUT" | grep -q "^VALIDATION_RESULT=OK$"; then
    exit 0
elif echo "$OUTPUT" | grep -qE "^VALIDATION_RESULT=FAIL:[0-9]+"; then
    exit 1
else
    echo "[validate] ERROR: did not find VALIDATION_RESULT marker (Godot failed before running script?)" >&2
    exit 2
fi
